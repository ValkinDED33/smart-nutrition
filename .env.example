NODE_ENV=development
SMART_NUTRITION_API_PORT=8787
SMART_NUTRITION_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
SMART_NUTRITION_ACCESS_TTL_MS=900000
SMART_NUTRITION_REFRESH_TTL_MS=604800000
SMART_NUTRITION_PASSWORD_ITERATIONS=180000
SMART_NUTRITION_BODY_LIMIT_BYTES=5242880
SMART_NUTRITION_BACKUP_INTERVAL_MS=600000
SMART_NUTRITION_MAX_BACKUPS=24
SMART_NUTRITION_RATE_LIMIT_WINDOW_MS=60000
SMART_NUTRITION_RATE_LIMIT_MAX=180
SMART_NUTRITION_SERVE_STATIC=true
SMART_NUTRITION_STATIC_DIR=dist
SMART_NUTRITION_DB_PATH=server/data/smart-nutrition.sqlite

# Frontend builds must point to a reachable API base URL.
# Local Vite can also use the /api proxy, but deployed Vercel builds need a public backend URL.
# Example for Vercel: VITE_SMART_NUTRITION_API_BASE_URL=https://your-api.example.com/api
VITE_SMART_NUTRITION_API_BASE_URL=

# Backend CORS must include the deployed frontend origin when frontend and API are on different domains.
# Example: SMART_NUTRITION_CORS_ORIGINS=https://smart-nutrition-nine.vercel.app
SMART_NUTRITION_APP_BASE_URL=http://localhost:5173
SMART_NUTRITION_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SMART_NUTRITION_AUTH_COOKIE_SAME_SITE=Lax
SMART_NUTRITION_AUTH_COOKIE_SECURE=false

SMART_NUTRITION_ASSISTANT_API_KEY=
SMART_NUTRITION_ASSISTANT_MODEL=
SMART_NUTRITION_ASSISTANT_PROVIDER=
SMART_NUTRITION_ASSISTANT_BASE_URL=https://api.openai.com/v1
SMART_NUTRITION_ASSISTANT_API_PATH=/chat/completions
SMART_NUTRITION_ASSISTANT_PROVIDER_ORDER=openrouter,groq,google
SMART_NUTRITION_ASSISTANT_TEMPERATURE=0.4
SMART_NUTRITION_ASSISTANT_MEMORY_LIMIT=16
SMART_NUTRITION_ASSISTANT_TIMEOUT_MS=20000
SMART_NUTRITION_ASSISTANT_RETRY_COOLDOWN_MS=300000

SMART_NUTRITION_OPENROUTER_API_KEY=
SMART_NUTRITION_OPENROUTER_MODEL=
SMART_NUTRITION_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SMART_NUTRITION_OPENROUTER_TIMEOUT_MS=20000
SMART_NUTRITION_OPENROUTER_HTTP_REFERER=http://localhost:5173
SMART_NUTRITION_OPENROUTER_TITLE=Smart Nutrition

SMART_NUTRITION_GROQ_API_KEY=
SMART_NUTRITION_GROQ_MODEL=
SMART_NUTRITION_GROQ_BASE_URL=https://api.groq.com/openai/v1
SMART_NUTRITION_GROQ_TIMEOUT_MS=20000

SMART_NUTRITION_GOOGLE_API_KEY=
SMART_NUTRITION_GOOGLE_MODEL=
SMART_NUTRITION_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SMART_NUTRITION_GOOGLE_TIMEOUT_MS=20000
