NODE_ENV=development
SMART_NUTRITION_API_PORT=8787
SMART_NUTRITION_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
SMART_NUTRITION_ACCESS_TTL_MS=900000
SMART_NUTRITION_REFRESH_TTL_MS=604800000
SMART_NUTRITION_PASSWORD_ITERATIONS=180000
SMART_NUTRITION_BODY_LIMIT_BYTES=5242880
SMART_NUTRITION_BACKUP_INTERVAL_MS=600000
SMART_NUTRITION_MAX_BACKUPS=24
SMART_NUTRITION_RATE_LIMIT_WINDOW_MS=60000
SMART_NUTRITION_RATE_LIMIT_MAX=180
SMART_NUTRITION_SERVE_STATIC=true
SMART_NUTRITION_STATIC_DIR=/app/dist
SMART_NUTRITION_DB_PATH=/app/server/data/smart-nutrition.sqlite

# ============================================================================
# AI PROVIDERS CONFIGURATION
# ============================================================================
# Select which provider to use: "openrouter", "groq", or "google"
SMART_NUTRITION_AI_PROVIDER=openrouter

# OpenRouter.ai - Production-ready, supports 200+ models
# Get API key at: https://openrouter.ai/keys
SMART_NUTRITION_OPENROUTER_API_KEY=
SMART_NUTRITION_OPENROUTER_MODEL=meta-llama/llama-2-70b-chat
SMART_NUTRITION_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SMART_NUTRITION_OPENROUTER_TIMEOUT_MS=30000

# Groq - Ultra-fast inference, free tier available
# Get API key at: https://console.groq.com/keys
SMART_NUTRITION_GROQ_API_KEY=
SMART_NUTRITION_GROQ_MODEL=mixtral-8x7b-32768
SMART_NUTRITION_GROQ_BASE_URL=https://api.groq.com/openai/v1
SMART_NUTRITION_GROQ_TIMEOUT_MS=30000

# Google Gemini - Latest models, free tier available
# Get API key at: https://aistudio.google.com/app/apikey
SMART_NUTRITION_GOOGLE_API_KEY=
SMART_NUTRITION_GOOGLE_MODEL=gemini-pro
SMART_NUTRITION_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
SMART_NUTRITION_GOOGLE_TIMEOUT_MS=30000

# Common AI settings
SMART_NUTRITION_AI_TEMPERATURE=0.4
SMART_NUTRITION_AI_MAX_TOKENS=1000
SMART_NUTRITION_AI_TIMEOUT_MS=30000

# Assistant-specific settings
SMART_NUTRITION_ASSISTANT_MEMORY_LIMIT=16
SMART_NUTRITION_ASSISTANT_TIMEOUT_MS=20000
SMART_NUTRITION_ASSISTANT_FALLBACK_TO_LOCAL=true
