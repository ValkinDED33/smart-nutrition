# Paste these variables into Render -> Service -> Environment.
# Replace CHANGE_ME values before deploying.

NODE_ENV=production

# Render provides PORT automatically. Set SMART_NUTRITION_API_PORT only if you
# intentionally want to override it.
# SMART_NUTRITION_API_PORT=10000

SMART_NUTRITION_APP_BASE_URL=https://smart-nutrition-nine.vercel.app
SMART_NUTRITION_CORS_ORIGINS=https://smart-nutrition-nine.vercel.app

SMART_NUTRITION_AUTH_COOKIE_SAME_SITE=None
SMART_NUTRITION_AUTH_COOKIE_SECURE=true

# Required in production. Generate a long random value and keep it secret.
SMART_NUTRITION_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

SMART_NUTRITION_ACCESS_TTL_MS=900000
SMART_NUTRITION_REFRESH_TTL_MS=604800000
SMART_NUTRITION_PASSWORD_ITERATIONS=180000
SMART_NUTRITION_BODY_LIMIT_BYTES=5242880
SMART_NUTRITION_BACKUP_INTERVAL_MS=600000
SMART_NUTRITION_MAX_BACKUPS=24
SMART_NUTRITION_RATE_LIMIT_WINDOW_MS=60000
SMART_NUTRITION_RATE_LIMIT_MAX=180
SMART_NUTRITION_PRODUCT_SUBMISSION_DAILY_LIMIT=12

# Backend-only Render service. Keep static frontend on Vercel.
# If you use the Render URL as the app too, set SMART_NUTRITION_SERVE_STATIC=true.
SMART_NUTRITION_SERVE_STATIC=false
SMART_NUTRITION_STATIC_DIR=/app/dist
# Create a Render persistent disk mounted at /var/data before relying on SQLite in production.
SMART_NUTRITION_DB_PATH=/var/data/smart-nutrition.sqlite
SMART_NUTRITION_BACKUP_DIR=/var/data/backups

# Optional SMTP for password reset emails.
SMART_NUTRITION_SMTP_URL=
SMART_NUTRITION_SMTP_HOST=
SMART_NUTRITION_SMTP_PORT=587
SMART_NUTRITION_SMTP_SECURE=false
SMART_NUTRITION_SMTP_USER=
SMART_NUTRITION_SMTP_PASS=
SMART_NUTRITION_EMAIL_FROM=
SMART_NUTRITION_EMAIL_FROM_NAME=Smart Nutrition

# AI assistant providers. Set at least one provider key + model to enable cloud AI.
# Important: do not set a MODEL without the matching API_KEY.
SMART_NUTRITION_ASSISTANT_PROVIDER_ORDER=openrouter,groq,google
SMART_NUTRITION_ASSISTANT_TEMPERATURE=0.4
SMART_NUTRITION_ASSISTANT_MEMORY_LIMIT=16
SMART_NUTRITION_ASSISTANT_TIMEOUT_MS=20000
SMART_NUTRITION_ASSISTANT_RETRY_COOLDOWN_MS=300000

SMART_NUTRITION_OPENROUTER_API_KEY=
SMART_NUTRITION_OPENROUTER_MODEL=
SMART_NUTRITION_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SMART_NUTRITION_OPENROUTER_TIMEOUT_MS=30000
SMART_NUTRITION_OPENROUTER_HTTP_REFERER=https://smart-nutrition-nine.vercel.app
SMART_NUTRITION_OPENROUTER_TITLE=Smart Nutrition

SMART_NUTRITION_GROQ_API_KEY=
SMART_NUTRITION_GROQ_MODEL=
SMART_NUTRITION_GROQ_BASE_URL=https://api.groq.com/openai/v1
SMART_NUTRITION_GROQ_TIMEOUT_MS=30000

SMART_NUTRITION_GOOGLE_API_KEY=
SMART_NUTRITION_GOOGLE_MODEL=
SMART_NUTRITION_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SMART_NUTRITION_GOOGLE_TIMEOUT_MS=30000
